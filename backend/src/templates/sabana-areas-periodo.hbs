<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Sábana de Áreas por Periodo</title>
    <style>
        @page {
            size: Legal landscape;
            margin: 10mm;
        }

        body {
            font-family: 'Segoe UI', Helvetica, Arial, sans-serif;
            font-size: 11px;
            margin: 0;
            color: #334155;
        }

        .header-wrapper {
            border-bottom: 2px solid #2563eb;
            padding-bottom: 8px;
            margin-bottom: 12px;
        }

        .header-table {
            width: 100%;
            border-collapse: collapse;
            border: none;
        }

        .header-table td {
            border: none;
            vertical-align: middle;
        }

        .inst-title {
            margin: 0;
            font-size: 16px;
            color: #1e3a8a;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 800;
        }

        .inst-subtitle {
            margin: 3px 0 0 0;
            font-size: 11px;
            color: #64748b;
        }

        .report-badge {
            background-color: #f5f3ff;
            border: 1px solid #ddd6fe;
            padding: 6px 12px;
            border-radius: 6px;
            text-align: right;
            float: right;
        }

        .report-badge h2 {
            margin: 0;
            font-size: 13px;
            color: #4338ca;
            text-transform: uppercase;
        }

        .report-badge p {
            margin: 2px 0 0 0;
            font-size: 11px;
            color: #6d28d9;
            font-weight: bold;
        }

        .meta-container {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            font-size: 11px;
        }

        .meta-item {
            display: inline-block;
            margin-right: 15px;
        }

        .meta-label {
            color: #64748b;
            font-weight: bold;
        }

        .meta-value {
            color: #0f172a;
            font-weight: 600;
            border-bottom: 1px dashed #cbd5e1;
            padding-bottom: 1px;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 11px;
        }

        .data-table th,
        .data-table td {
            border: 1px solid #cbd5e1;
            padding: 4px 2px;
            text-align: center;
        }

        .data-table th {
            background-color: #f8fafc;
            color: #334155;
            font-weight: 700;
            font-size: 11px;
        }

        .align-left {
            text-align: left !important;
            padding-left: 6px !important;
        }

        .col-nro {
            width: 2.5%;
            color: #64748b;
        }

        .col-nombre {
            width: 26%;
            font-weight: 600;
            color: #0f172a;
        }

        .col-area {
            width: 3.8%;
        }

        .col-stats {
            width: 3.5%;
            background-color: #f1f5f9;
            font-weight: bold;
        }

        .col-recup {
            width: 4.5%;
            color: #94a3b8;
        }

        .data-table tbody tr:nth-child(even) {
            background-color: #fbfbfc;
        }

        /* Footer Estadístico Modernizado */
        .stats-footer td {
            font-weight: 600;
            background-color: #fff !important;
            color: #475569;
        }

        .stats-highlight {
            color: #b91c1c;
            font-weight: 800;
            font-size: 11px;
        }
    </style>
</head>

<body>

    <div class="header-wrapper">
        <table class="header-table">
            <tr>
                <td style="width: 60px;">
                    {{#if urlEscudo}}
                    <img src="{{urlEscudo}}" alt="Logo" style="max-height: 50px; max-width: 50px;">
                    {{/if}}
                </td>
                <td style="padding-left: 10px;">
                    <h1 class="inst-title">{{nombreInstitucion}}</h1>
                    <p class="inst-subtitle">Sede: <strong>{{sedeNombre}}</strong> | Año Lectivo:
                        <strong>{{anioLectivo}}</strong> | Jornada: <strong>{{jornada}}</strong></p>
                </td>
                <td>
                    <div class="report-badge">
                        <h2>Rendimiento de Áreas</h2>
                        <p>Periodo Evaluado: {{periodo}}</p>
                    </div>
                </td>
            </tr>
        </table>
    </div>

    <div class="meta-container">
        <div class="meta-item"><span class="meta-label">Grado:</span> <span class="meta-value">{{gradoNombre}}</span>
        </div>
        <div class="meta-item"><span class="meta-label">Grupo:</span> <span class="meta-value">{{grupoNombre}}</span>
        </div>
        <div class="meta-item"><span class="meta-label">Director de Grupo:</span> <span
                class="meta-value">{{directorNombre}}</span></div>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th class="col-nro">#</th>
                <th class="align-left col-nombre">Estudiante</th>
                {{#each areas}}
                <th class="col-area">{{this}}</th>
                {{/each}}
                <th class="col-stats">Suma</th>
                <th class="col-stats">Puesto</th>
                <th class="col-stats">Áreas Perd.</th>
                <th class="col-stats">Promedio</th>
                <th class="col-recup">Recup 1</th>
                <th class="col-recup">Recup 2</th>
            </tr>
        </thead>
        <tbody>
            {{#each estudiantes}}
            <tr>
                <td class="col-nro">{{this.numero}}</td>
                <td class="align-left col-nombre">{{this.nombreCompleto}}</td>

                {{#each this.notasAreas}}
                <td>{{this}}</td>
                {{/each}}

                <td style="background-color: #f8fafc;">{{this.suma}}</td>
                <td style="background-color: #f8fafc; font-weight: bold; color: #0369a1;">{{this.puesto}}</td>
                <td style="background-color: #fef2f2; color: #b91c1c; font-weight: bold;">{{this.nroAp}}</td>
                <td style="background-color: #f8fafc; font-weight: bold;">{{this.prom}}</td>
                <td></td>
                <td></td>
            </tr>
            {{/each}}
        </tbody>
        <tfoot>
            <tr class="stats-footer">
                <td colspan="2" class="align-left" style="color: #0a7c34;">Estudiantes que aprueban el área:</td>
                {{#each aprueban}}
                <td style="color: #0a7c34;">{{this}}</td>
                {{/each}}
                <td colspan="6" class="align-left" style="padding-left: 15px;">Estudiantes con 3 o más áreas perdidas:
                    <span class="stats-highlight">{{tresOMasPerdidas}}</span></td>
            </tr>
            <tr class="stats-footer">
                <td colspan="2" class="align-left" style="color: #b91c1c;">Estudiantes que reprueban el área:</td>
                {{#each reprueban}}
                <td style="color: #b91c1c;">{{this}}</td>
                {{/each}}
                <td colspan="6"></td>
            </tr>
        </tfoot>
    </table>

</body>

</html>
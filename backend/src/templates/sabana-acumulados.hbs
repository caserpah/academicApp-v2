<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Sábana de Acumulados por Área</title>
    <style>
        @page {
            size: Legal landscape;
            margin: 10mm;
        }

        body {
            font-family: 'Segoe UI', Helvetica, Arial, sans-serif;
            font-size: 10px;
            margin: 0;
            color: #334155;
        }

        .header-wrapper {
            border-bottom: 2px solid #2563eb;
            padding-bottom: 8px;
            margin-bottom: 12px;
        }

        .header-table {
            width: 100%;
            border-collapse: collapse;
            border: none;
        }

        .header-table td {
            border: none;
            vertical-align: middle;
        }

        .inst-title {
            margin: 0;
            font-size: 16px;
            color: #1e3a8a;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 800;
        }

        .inst-subtitle {
            margin: 3px 0 0 0;
            font-size: 11px;
            color: #64748b;
        }

        .report-badge {
            background-color: #ecfdf5;
            border: 1px solid #bbf7d0;
            padding: 6px 12px;
            border-radius: 6px;
            text-align: right;
            float: right;
        }

        .report-badge h2 {
            margin: 0;
            font-size: 13px;
            color: #15803d;
            text-transform: uppercase;
        }

        .report-badge p {
            margin: 2px 0 0 0;
            font-size: 10px;
            color: #166534;
            font-weight: bold;
        }

        /* Panel de Referencia Moderno */
        .ref-panel {
            float: right;
            margin-top: -5px;
            margin-bottom: 10px;
            background-color: #f8fafc;
            border: 1px solid #cbd5e1;
            border-radius: 4px;
            padding: 5px;
            font-size: 11px;
        }

        .ref-table {
            border-collapse: collapse;
        }

        .ref-table th,
        .ref-table td {
            padding: 2px 8px;
            text-align: center;
            border-bottom: 1px solid #e2e8f0;
        }

        .ref-table th {
            color: #475569;
            font-weight: 700;
            text-transform: uppercase;
        }

        .ref-table tr:last-child td {
            border-bottom: none;
        }

        .meta-container {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            font-size: 11px;
            width: 70%;
        }

        .meta-item {
            display: inline-block;
            margin-right: 15px;
        }

        .meta-label {
            color: #64748b;
            font-weight: bold;
        }

        .meta-value {
            color: #0f172a;
            font-weight: 600;
            border-bottom: 1px dashed #cbd5e1;
            padding-bottom: 1px;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 11px;
            clear: both;
        }

        .data-table th,
        .data-table td {
            border: 1px solid #cbd5e1;
            padding: 4px 1px;
            text-align: center;
        }

        .data-table th {
            background-color: #f1f5f9;
            color: #334155;
            font-weight: 700;
            font-size: 11px;
        }

        .align-left {
            text-align: left !important;
            padding-left: 6px !important;
        }

        /* Ajusté el ancho del nombre al quitar las columnas extra */
        .col-nro {
            width: 3%;
            color: #64748b;
        }

        .col-nombre {
            width: 30%;
            font-weight: 600;
            color: #0f172a;
        }

        .col-sub {
            font-size: 11px;
            color: #475569;
        }

        .data-table tbody tr:nth-child(even) {
            background-color: #fbfbfc;
        }

        .val-suma {
            font-weight: 700;
            color: #000;
            font-size: 11px;
        }

        .val-n {
            color: #334155;
            font-size: 11px;
            font-weight: bold;
        }
    </style>
</head>

<body>

    <div class="header-wrapper">
        <table class="header-table">
            <tr>
                <td style="width: 60px;">
                    {{#if urlEscudo}}
                    <img src="{{urlEscudo}}" alt="Logo" style="max-height: 50px; max-width: 50px;">
                    {{/if}}
                </td>
                <td style="padding-left: 10px;">
                    <h1 class="inst-title">{{nombreInstitucion}}</h1>
                    <p class="inst-subtitle">Sede: <strong>{{sedeNombre}}</strong> | Año Lectivo:
                        <strong>{{anioLectivo}}</strong> | Jornada: <strong>{{jornada}}</strong>
                    </p>
                </td>
                <td>
                    <div class="report-badge">
                        <h2>Consolidado de Acumulados</h2>
                        <p>Áreas Académicas</p>
                    </div>
                </td>
            </tr>
        </table>
    </div>

    <div class="ref-panel">
        <table class="ref-table">
            <tr>
                <th>Periodo</th>
                <th>Suma Mínima</th>
                <th>Requisito</th>
            </tr>
            <tr>
                <td>1</td>
                <td>3,0</td>
                <td>1 Nota</td>
            </tr>
            <tr>
                <td>2</td>
                <td>6,0</td>
                <td>2 Notas</td>
            </tr>
            <tr>
                <td>3</td>
                <td>9,0</td>
                <td>3 Notas</td>
            </tr>
            <tr>
                <td>4</td>
                <td>11,8</td>
                <td>4 Notas</td>
            </tr>
        </table>
    </div>

    <div class="meta-container">
        <div class="meta-item"><span class="meta-label">Grado:</span> <span class="meta-value">{{gradoNombre}}</span>
        </div>
        <div class="meta-item"><span class="meta-label">Grupo:</span> <span class="meta-value">{{grupoNombre}}</span>
        </div>
        <div class="meta-item"><span class="meta-label">Director de Grupo:</span> <span
                class="meta-value">{{directorNombre}}</span></div>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th rowspan="2" class="col-nro">#</th>
                <th rowspan="2" class="align-left col-nombre">Estudiante</th>
                {{#each areas}}
                <th colspan="2" style="background-color: #e2e8f0;">{{this}}</th>
                {{/each}}
            </tr>
            <tr>
                {{#each areas}}
                <th class="col-sub">SUM</th>
                <th class="col-sub">N</th>
                {{/each}}
            </tr>
        </thead>
        <tbody>
            {{#each estudiantes}}
            <tr>
                <td class="col-nro">{{this.numero}}</td>
                <td class="align-left col-nombre">{{this.nombreCompleto}}</td>

                {{#each this.acumulados}}
                <td class="val-suma">{{this.suma}}</td>
                <td class="val-n">{{this.n}}</td>
                {{/each}}
            </tr>
            {{/each}}
        </tbody>
    </table>

</body>

</html>
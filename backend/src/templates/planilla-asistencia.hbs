<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Planilla de Asistencia</title>
    <style>
        @page {
            size: A4 portrait;
            margin: 10mm;
        }

        body {
            font-family: Arial, sans-serif;
            font-size: 10px;
            margin: 0;
            padding: 0;
            color: #000;
        }

        /* Encabezado */
        .header-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 5px;
        }

        .header-table td {
            border: 1px solid #000;
            padding: 5px;
            text-align: center;
        }

        .logo-cell {
            width: 15%;
        }

        .logo-cell img {
            max-width: 60px;
            max-height: 60px;
        }

        .info-cell h2 {
            margin: 0 0 5px 0;
            font-size: 14px;
            text-transform: uppercase;
        }

        .info-cell h3 {
            margin: 0 0 3px 0;
            font-size: 12px;
        }

        .info-cell h4 {
            margin: 0;
            font-size: 11px;
            font-weight: normal;
        }

        /* Meta info (Docente, Asignatura, etc.) */
        .meta-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 10px;
            font-size: 10px;
            font-weight: bold;
        }

        .meta-table td {
            padding: 3px 0;
        }

        .linea {
            border-bottom: 1px solid #000;
            display: inline-block;
            min-width: 150px;
            margin-left: 5px;
        }

        /* Tabla Principal */
        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 10px;
        }

        .data-table th,
        .data-table td {
            border: 1px solid #000;
            padding: 3px;
        }

        .data-table th {
            background-color: #f2f2f2;
            text-align: center;
        }

        /* Anchos de columna */
        .col-no {
            width: 3%;
            text-align: center;
            font-weight: bold;
        }

        .col-doc {
            width: 12%;
            text-align: center;
        }

        .col-nombre {
            width: 41%;
            text-align: left;
            font-weight: bold;
        }

        .col-dia {
            width: 2.2%;
            text-align: center;
            height: 26px;
        }

        /* 20 columnas ajustadas */

        /* Firmas */
        .firmas {
            width: 100%;
            margin-top: 50px;
            text-align: center;
            font-size: 11px;
            font-weight: bold;
            page-break-inside: avoid;
        }

        .firmas td {
            width: 50%;
            padding-top: 30px;
        }

        .linea-firma {
            border-top: 1px solid #000;
            width: 60%;
            margin: 0 auto 5px auto;
        }

        .page-break {
            page-break-after: always;
        }

        .page-break:last-child {
            page-break-after: auto;
        }
    </style>
</head>

<body>

    {{#each paginas}}
    <div class="page-break">

        <table class="header-table">
            <tr>
                <td class="logo-cell"><img src="{{urlEscudo}}" alt="Escudo"></td>
                <td class="info-cell">
                    <h2>{{nombreInstitucion}}</h2>
                    <h3>SEDE: {{sedeNombre}}</h3>
                    <h4>{{tituloPlanilla}} - AÑO LECTIVO {{anioLectivo}}</h4>
                </td>
            </tr>
        </table>

        <table class="meta-table">
            <tr>
                <td width="50%">DOCENTE: <b>{{this.docenteNombre}}</b></td>
                <td width="50%">ASIGNATURA: <b>{{this.asignaturaNombre}}</b></td>
            </tr>
            <tr>
                <td>GRADO: {{this.gradoNombre}} &nbsp;&nbsp;&nbsp; GRUPO: {{this.grupoNombre}}</td>
                <td>PERIODO: <b>{{this.periodo}}</b> &nbsp;&nbsp;&nbsp; JORNADA: {{this.jornada}}</td>
            </tr>
        </table>

        <table class="data-table">
            <thead>
                <tr>
                    <th rowspan="2" class="col-no">No</th>
                    <th rowspan="2" class="col-doc">DOCUMENTO</th>
                    <th rowspan="2" class="col-nombre">APELLIDOS Y NOMBRES</th>
                    <th colspan="20" style="text-align: left; padding-left: 10px; font-size: 11px;">Mes:
                        __________________
                    </th>
                </tr>
                <tr>
                    {{#each columnasAsistencia}}
                    <th class="col-dia"></th>
                    {{/each}}
                </tr>
            </thead>
            <tbody>
                {{#each estudiantes}}
                <tr>
                    <td class="col-no">{{this.numero}}</td>
                    <td class="col-doc">{{this.documento}}</td>
                    <td class="col-nombre">{{this.nombreCompleto}}</td>
                    {{#each ../columnasAsistencia}}
                    <td></td>
                    {{/each}}
                </tr>
                {{/each}}
            </tbody>
        </table>

        <table class="firmas">
            <tr>
                <td>
                    <div class="linea-firma"></div>
                    FIRMA DEL DOCENTE
                </td>
                <td>
                    <div class="linea-firma"></div>
                    VoBo COORDINACIÓN
                </td>
            </tr>
        </table>

    </div>
    {{/each}}

</body>

</html>